{
  "name": "brasildados",
  "version": "0.1.0",
  "description": "Ingestão de dados públicos brasileiros para análise comparativa de governos",
  "type": "module",
  "scripts": {
    "ingest:bcb": "node ingest/bcb.mjs",
    "ingest:ipea": "node ingest/ipea.mjs",
    "ingest:tse": "node ingest/tse.mjs",
    "ingest:ibge": "node ingest/ibge.mjs",
    "ingest:social": "node ingest/social.mjs",
    "ingest:empresas": "node ingest/empresas.mjs",
    "ingest:all": "node ingest/presidents.mjs && node ingest/bcb.mjs && node ingest/ipea.mjs && node ingest/ibge.mjs && node ingest/cti.mjs && node ingest/tse.mjs",
    "photos": "node tools/fetch-president-photos.mjs",
    "presidents": "node ingest/presidents.mjs",
    "presidents:legacy": "node ingest/presidents-legacy.mjs",
    "api": "node api/server.mjs",
    "download:all": "node ingest/download-all.mjs",
    "download:retry": "node ingest/download-retry.mjs",
    "download:tse": "node ingest/download-all.mjs --only=tse",
    "download:inep": "node ingest/download-all.mjs --only=inep",
    "download:ibge": "node ingest/download-all.mjs --only=ibge",
    "relatorio": "type D:\\brasildados\\logs\\relatorio.md"
  },
  "dependencies": {
    "adm-zip": "^0.5.17",
    "node-fetch": "^3.3.2"
  }
